{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snf-schedule-optimizer/tools/e2e/scenario.schema.json",
  "type": "object",
  "required": ["name", "description", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "action"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "goto",
              "click_role",
              "click_test_id",
              "expect_role",
              "expect_test_id",
              "expect_text",
              "wait_for_url",
              "sleep"
            ]
          },
          "url": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "namePattern": {
            "type": "string"
          },
          "testId": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "pattern": {
            "type": "string"
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 0
          },
          "durationMs": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
